# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Banco de dados PostgreSQL
# Use DATABASE_URL como entrada principal em Railway e outros clouds.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cartorio
DB_USER=cartorio_user
DB_PASSWORD=TROQUE_ESTA_SENHA
DB_SSL=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# JWT — use uma string longa e aleatória
JWT_SECRET=TROQUE_POR_UMA_STRING_LONGA_E_ALEATORIA_AQUI
JWT_EXPIRES_IN=8h

# Servidor
HOST=0.0.0.0
PORT=3001
NODE_ENV=production

# CORS
# Exemplo: https://app.seudominio.com.br
# Para múltiplas origens: https://app.seudominio.com.br,http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:4173,http://127.0.0.1:4173
APP_BASE_URL=http://localhost:3001
